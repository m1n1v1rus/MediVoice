# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/medivoice
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/medivoice

# JWT Configuration
JWT_SECRET=replace_with_strong_secret_key_here
JWT_EXPIRE=7d

# Twilio Configuration (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# AI Service Configuration
AI_SERVICE_URL=http://localhost:8000

# Hospital/Clinic Configuration
HOSPITAL_NAME=MediVoice Hospital
REMINDER_TIME=09:00